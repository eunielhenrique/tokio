# Secrets da Edge Function (configure com: supabase secrets set --env-file .env)
# SUPABASE_URL e SUPABASE_SERVICE_ROLE_KEY são injetadas automaticamente pelo Supabase.

# WhatsApp Cloud API (Meta)
WHATSAPP_TOKEN=                       # token permanente do app Meta (o mesmo usado no n8n)
WHATSAPP_PHONE_NUMBER_ID=881902981671358
META_VERIFY_TOKEN=tebox-sdr           # valor livre; repita na configuração do webhook na Meta

# Claude (Anthropic) — usado pelos dois agentes de IA
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-opus-4-8

# Google (Calendar + Gmail) — gere um refresh token novo (instruções no README)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REFRESH_TOKEN=
GOOGLE_CALENDAR_ID=eunielhenrique@gmail.com

# CRM (ROI Chat) — webhook usado pelo fluxo original
CRM_WEBHOOK_URL=https://roichatpartner.com.br/api/iwh/246da07376f77016aafb0b9d66593dfd
CRM_COPY_EMAIL=alexandre@toyboxdiversoes.com
